    "\n",
    "\n",
    "print(\"\\n===================================\")\n",
    "print(\"INVENTORY DATA VALIDATION STARTED\")\n",
    "print(\"===================================\\n\")\n",
    "\n",
    "\n",
    "# =========================================================\n",
    "# 1. BASIC STRUCTURAL VALIDATION\n",
    "# =========================================================\n",
    "\n",
    "print(\"1. STRUCTURAL VALIDATION\")\n",
    "\n",
    "\n",
    "# ---------------------------------------------------------\n",
    "# inventory_id uniqueness\n",
    "# ---------------------------------------------------------\n",
    "\n",
    "assert (\n",
    "    df_inventory[\"inventory_id\"]\n",
    "    .is_unique\n",
    "), \"Duplicate inventory_id found\"\n",
    "\n",
    "\n",
    "# ---------------------------------------------------------\n",
    "# Mandatory columns no nulls\n",
    "# ---------------------------------------------------------\n",
    "\n",
    "mandatory_cols = [\n",
    "\n",
    "    \"component_id\",\n",
    "    \"supplier_id\",\n",
    "    \"current_stock\",\n",
    "    \"avg_daily_consumption\",\n",
    "    \"safety_stock\",\n",
    "    \"plant_id\"\n",
    "\n",
    "]\n",
    "\n",
    "assert (\n",
    "\n",
    "    df_inventory[mandatory_cols]\n",
    "\n",
    "    .isnull()\n",
    "\n",
    "    .sum()\n",
    "\n",
    "    .sum()\n",
    "\n",
    "    == 0\n",
    "\n",
    "), \"Null values found in mandatory columns\"\n",
    "\n",
    "\n",
    "print(\"✓ Structural validation passed\")\n",
    "\n",
    "\n",
    "# =========================================================\n",
    "# 2. SUPPLIER RELATIONSHIP VALIDATION\n",
    "# =========================================================\n",
    "\n",
    "print(\"\\n2. SUPPLIER RELATIONSHIP VALIDATION\")\n",
    "\n",
    "\n",
    "# ---------------------------------------------------------\n",
    "# supplier_id exists in supplier_master\n",
    "# ---------------------------------------------------------\n",
    "\n",
    "assert (\n",
    "\n",
    "    df_inventory[\"supplier_id\"]\n",
    "\n",
    "    .isin(df_suppliers[\"supplier_id\"])\n",
    "\n",
    "    .all()\n",
    "\n",
    "), \"Invalid supplier_id found in inventory table\"\n",
    "\n",
    "\n",
    "print(\"✓ Supplier FK validation passed\")\n",
    "\n",
    "\n",
    "# =========================================================\n",
    "# 3. COMPONENT LINEAGE VALIDATION\n",
    "# =========================================================\n",
    "\n",
    "print(\"\\n3. COMPONENT LINEAGE VALIDATION\")\n",
    "\n",
    "\n",
