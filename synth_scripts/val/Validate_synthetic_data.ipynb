    "\n",
    "    df_inventory[\"component_id\"]\n",
    "\n",
    "    .isin(df_po[\"component_id\"])\n",
    "\n",
    "    .all()\n",
    "\n",
    "), \"Inventory contains unknown component_id\"\n",
    "\n",
    "\n",
    "print(\"✓ Component lineage validation passed\")\n",
    "\n",
    "\n",
    "# =========================================================\n",
