    "# ---------------------------------------------------------\n",
    "# Aggregate rejected units by PO\n",
    "# ---------------------------------------------------------\n",
    "\n",
    "quality_summary = (\n",
    "\n",
    "    df_quality_inspections\n",
    "\n",
    "    .groupby(\"po_id\")[\"rejected_units\"]\n",
    "\n",
    "    .sum()\n",
    "\n",
    "    .reset_index()\n",
    "\n",
    ")\n",
    "\n",
    "quality_summary.rename(\n",
    "\n",
    "    columns={\n",
    "        \"rejected_units\":\n",
    "        \"total_rejected\"\n",
    "    },\n",
    "\n",
    "    inplace=True\n",
    ")\n",
    "\n",
    "\n",
    "# ---------------------------------------------------------\n",
    "# Merge with PO\n",
    "# ---------------------------------------------------------\n",
    "\n",
    "po_validation = df_po.merge(\n",
    "\n",
    "    quality_summary,\n",
    "\n",
    "    on=\"po_id\",\n",
    "\n",
    "    how=\"left\"\n",
    "\n",
    ")\n",
    "\n",
    "\n",
    "po_validation[\"total_rejected\"] = (\n",
    "\n",
    "    po_validation[\"total_rejected\"]\n",
    "\n",
    "    .fillna(0)\n",
    "\n",
    ")\n",
    "\n",
    "\n",
    "# ---------------------------------------------------------\n",
    "# Compute usable inventory\n",
    "# ---------------------------------------------------------\n",
    "\n",
    "po_validation[\"usable_inventory\"] = (\n",
    "\n",
    "    po_validation[\"received_quantity\"]\n",
    "\n",
    "    - po_validation[\"total_rejected\"]\n",
    "\n",
    ")\n",
    "\n",
    "po_validation[\"usable_inventory\"] = (\n",
    "\n",
    "    po_validation[\"usable_inventory\"]\n",
    "\n",
    "    .clip(lower=0)\n",
    "\n",
    ")\n",
    "\n",
    "\n",
    "# ---------------------------------------------------------\n",
    "# AGGREGATE usable inventory\n",
    "# THIS IS THE FIX\n",
    "# ---------------------------------------------------------\n",
    "\n",
    "usable_inventory_summary = (\n",
    "\n",
    "    po_validation\n",
    "\n",
    "    .groupby([\n",
    "        \"supplier_id\",\n",
    "        \"component_id\"\n",
    "    ])[\"usable_inventory\"]\n",
    "\n",
    "    .sum()\n",
    "\n",
    "    .reset_index()\n",
    "\n",
    ")\n",
    "\n",
    "\n",
    "# ---------------------------------------------------------\n",
    "# Merge with inventory table\n",
    "# ---------------------------------------------------------\n",
    "\n",
    "inventory_validation = df_inventory.merge(\n",
    "\n",
    "    usable_inventory_summary,\n",
    "\n",
    "    on=[\n",
    "        \"supplier_id\",\n",
    "        \"component_id\"\n",
    "    ],\n",
    "\n",
    "    how=\"left\"\n",
    "\n",
    ")\n",
    "\n",
    "\n",
    "inventory_validation[\n",
    "    \"usable_inventory\"\n",
    "] = inventory_validation[\n",
    "    \"usable_inventory\"\n",
    "].fillna(0)\n",
    "\n",
    "\n",
    "# ---------------------------------------------------------\n",
    "# OPTIONAL BUFFER\n",
    "# ---------------------------------------------------------\n",
    "# Inventory systems may have:\n",
    "# - timing differences\n",
    "# - delayed consumption updates\n",
    "# - warehouse sync lag\n",
    "#\n",
    "# Allow small operational tolerance\n",
    "# ---------------------------------------------------------\n",
    "\n",
    "tolerance_multiplier = 1.10\n",
    "\n",
    "\n",
    "# ---------------------------------------------------------\n",
    "# ASSERTION\n",
    "# ---------------------------------------------------------\n",
    "\n",
    "invalid_inventory = inventory_validation[\n",
    "\n",
    "    inventory_validation[\"current_stock\"]\n",
    "\n",
    "    >\n",
    "\n",
    "    (\n",
    "        inventory_validation[\"usable_inventory\"]\n",
    "\n",
    "        * tolerance_multiplier\n",
    "    )\n",
    "\n",
    "]\n",
    "\n",
    "\n",
    "assert len(invalid_inventory) == 0, (\n",
    "\n",
    "    f\"{len(invalid_inventory)} inventory records \"\n",
    "    f\"exceed usable inventory\"\n",
    ")\n",
    "\n",
    "\n",
    "print(\"✓ Usable inventory validation passed\")"
   ]
  },
