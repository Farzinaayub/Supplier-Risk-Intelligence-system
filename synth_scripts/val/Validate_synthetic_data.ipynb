    "import pandas as pd\n",
    "import numpy as np\n",
    "\n",
    "# =========================================================\n",
    "# ASSUMPTIONS\n",
    "# =========================================================\n",
    "# Existing DataFrames:\n",
    "#\n",
    "# df_suppliers\n",
    "# df_po\n",
    "# df_shipments\n",
    "# df_quality_inspections\n",
    "# df_inventory\n",
    "# df_supplier_audits\n",
    "# df_supplier_incidents\n",
    "#\n",
    "# =========================================================\n",
    "\n",
    "\n",
    "print(\"\\n===================================\")\n",
    "print(\"SUPPLIER INCIDENT VALIDATION STARTED\")\n",
    "print(\"===================================\\n\")\n",
    "\n",
    "\n",
    "# =========================================================\n",
    "# 1. STRUCTURAL VALIDATION\n",
    "# =========================================================\n",
    "\n",
    "print(\"1. STRUCTURAL VALIDATION\")\n",
    "\n",
    "\n",
    "# ---------------------------------------------------------\n",
    "# incident_id uniqueness\n",
    "# ---------------------------------------------------------\n",
    "\n",
    "assert (\n",
    "\n",
    "    df_supplier_incidents[\"incident_id\"]\n",
    "\n",
    "    .is_unique\n",
    "\n",
    "), \"Duplicate incident_id detected\"\n",
    "\n",
    "\n",
    "# ---------------------------------------------------------\n",
    "# Mandatory column validation\n",
    "# ---------------------------------------------------------\n",
    "\n",
    "mandatory_cols = [\n",
    "\n",
    "    \"incident_id\",\n",
    "    \"supplier_id\",\n",
    "    \"incident_date\",\n",
    "    \"incident_type\",\n",
    "    \"severity\",\n",
    "    \"operational_impact_hours\"\n",
    "\n",
    "]\n",
    "\n",
    "\n",
    "assert (\n",
    "\n",
    "    df_supplier_incidents[mandatory_cols]\n",
    "\n",
    "    .isnull()\n",
    "\n",
    "    .sum()\n",
    "\n",
    "    .sum()\n",
    "\n",
    "    == 0\n",
    "\n",
    "), \"Null values found in incident table\"\n",
    "\n",
    "\n",
    "print(\"✓ Structural validation passed\")\n",
    "\n",
    "\n",
    "# =========================================================\n",
    "# 2. SUPPLIER FK VALIDATION\n",
    "# =========================================================\n",
    "\n",
    "print(\"\\n2. SUPPLIER FK VALIDATION\")\n",
    "\n",
    "\n",
    "assert (\n",
    "\n",
    "    df_supplier_incidents[\"supplier_id\"]\n",
    "\n",
    "    .isin(df_suppliers[\"supplier_id\"])\n",
    "\n",
    "    .all()\n",
    "\n",
    "), \"Invalid supplier_id in incident table\"\n",
    "\n",
    "\n",
    "print(\"✓ Supplier FK validation passed\")\n",
    "\n",
    "\n",
    "# =========================================================\n",
    "# 3. INCIDENT TYPE VALIDATION\n",
    "# =========================================================\n",
    "\n",
    "print(\"\\n3. INCIDENT TYPE VALIDATION\")\n",
    "\n",
    "\n",
    "valid_incident_types = [\n",
    "\n",
    "    \"Shipment Delay\",\n",
    "    \"Port Congestion\",\n",
    "    \"Customs Hold\",\n",
    "    \"Carrier Failure\",\n",
    "\n",
    "    \"Quality Failure\",\n",
    "    \"Batch Rejection\",\n",
    "    \"Product Recall\",\n",
    "\n",
    "    \"Stockout\",\n",
    "    \"Supply Shortage\",\n",
    "\n",
    "    \"Audit Non-Compliance\",\n",
    "    \"Regulatory Violation\",\n",
    "\n",
    "    \"Production Shutdown\",\n",
    "    \"Labor Strike\",\n",
    "    \"Cybersecurity Incident\"\n",
    "\n",
    "]\n",
    "\n",
    "\n",
    "assert (\n",
    "\n",
    "    df_supplier_incidents[\"incident_type\"]\n",
    "\n",
    "    .isin(valid_incident_types)\n",
    "\n",
    "    .all()\n",
    "\n",
    "), \"Invalid incident_type detected\"\n",
    "\n",
    "\n",
    "print(\"✓ Incident type validation passed\")\n",
    "\n",
    "\n",
    "# =========================================================\n",
    "# 4. SEVERITY VALIDATION\n",
    "# =========================================================\n",
    "\n",
    "print(\"\\n4. SEVERITY VALIDATION\")\n",
    "\n",
    "\n",
    "valid_severity = [\n",
    "\n",
    "    \"Low\",\n",
    "    \"Medium\",\n",
    "    \"High\",\n",
    "    \"Critical\"\n",
    "\n",
    "]\n",
    "\n",
    "\n",
    "assert (\n",
    "\n",
    "    df_supplier_incidents[\"severity\"]\n",
    "\n",
    "    .isin(valid_severity)\n",
    "\n",
    "    .all()\n",
    "\n",
    "), \"Invalid severity detected\"\n",
    "\n",
    "\n",
    "print(\"✓ Severity validation passed\")\n",
    "\n",
    "\n",
    "# =========================================================\n",
    "# 5. IMPACT HOURS SANITY\n",
    "# =========================================================\n",
    "\n",
    "print(\"\\n5. IMPACT HOURS SANITY\")\n",
    "\n",
    "\n",
    "assert (\n",
    "\n",
    "    df_supplier_incidents[\n",
    "        \"operational_impact_hours\"\n",
    "    ]\n",
    "\n",
    "    > 0\n",
    "\n",
    ").all(), \"Negative or zero impact hours found\"\n",
    "\n",
    "\n",
    "# ---------------------------------------------------------\n",
    "# Severity should correlate with impact\n",
    "# ---------------------------------------------------------\n",
    "\n",
    "severity_ranges = {\n",
    "\n",
    "    \"Low\": (1, 8),\n",
    "\n",
    "    \"Medium\": (8, 24),\n",
    "\n",
    "    \"High\": (24, 72),\n",
    "\n",
    "    \"Critical\": (72, 240)\n",
    "\n",
    "}\n",
    "\n",
    "\n",
    "for severity, (low, high) in severity_ranges.items():\n",
    "\n",
    "    subset = df_supplier_incidents[\n",
    "\n",
    "        df_supplier_incidents[\"severity\"]\n",
    "        == severity\n",
    "\n",
    "    ]\n",
    "\n",
    "    if len(subset) > 0:\n",
    "\n",
    "        assert (\n",
    "\n",
    "            (\n",
    "                subset[\n",
    "                    \"operational_impact_hours\"\n",
    "                ]\n",
    "\n",
    "                >= low\n",
    "            )\n",
    "\n",
    "            &\n",
    "\n",
    "            (\n",
    "                subset[\n",
    "                    \"operational_impact_hours\"\n",
    "                ]\n",
    "\n",
    "                <= high\n",
    "            )\n",
    "\n",
    "        ).all(), (\n",
    "\n",
    "            f\"Invalid impact hours for severity {severity}\"\n",
    "        )\n",
    "\n",
    "\n",
    "print(\"✓ Impact hour validation passed\")\n",
    "\n",
    "\n",
    "# =========================================================\n",
    "# 6. SHIPMENT CORRELATION VALIDATION\n",
    "# =========================================================\n",
    "\n",
    "print(\"\\n6. SHIPMENT CORRELATION VALIDATION\")\n",
    "\n",
    "\n",
    "shipment_metrics = (\n",
    "\n",
    "    df_shipments\n",
    "\n",
    "    .groupby(\"supplier_id\")\n",
    "\n",
    "    .agg(\n",
    "\n",
    "        total_shipments=(\n",
    "            \"shipment_id\",\n",
    "            \"count\"\n",
    "        ),\n",
    "\n",
    "        delayed_shipments=(\n",
    "            \"shipment_status\",\n",
    "            lambda x:\n",
    "                (x == \"Delayed\").sum()\n",
    "        )\n",
    "\n",
    "    )\n",
    "\n",
    "    .reset_index()\n",
    "\n",
    ")\n",
    "\n",
    "shipment_metrics[\"delay_ratio\"] = (\n",
    "\n",
    "    shipment_metrics[\"delayed_shipments\"]\n",
    "\n",
    "    /\n",
    "\n",
    "    shipment_metrics[\"total_shipments\"]\n",
    "\n",
    ")\n",
    "\n",
    "\n",
    "incident_shipments = df_supplier_incidents.merge(\n",
    "\n",
    "    shipment_metrics,\n",
    "\n",
    "    on=\"supplier_id\",\n",
    "\n",
    "    how=\"left\"\n",
    "\n",
    ")\n",
    "\n",
    "\n",
    "incident_shipments[\"delay_ratio\"] = (\n",
    "\n",
    "    incident_shipments[\"delay_ratio\"]\n",
    "\n",
    "    .fillna(0)\n",
    "\n",
    ")\n",
    "\n",
    "\n",
    "# ---------------------------------------------------------\n",
    "# Suppliers with severe logistics incidents\n",
    "# should have meaningful shipment delays\n",
    "# ---------------------------------------------------------\n",
    "\n",
    "logistics_incidents = incident_shipments[\n",
    "\n",
    "    incident_shipments[\"incident_type\"]\n",
    "\n",
    "    .isin([\n",
    "        \"Shipment Delay\",\n",
    "        \"Port Congestion\",\n",
    "        \"Customs Hold\",\n",
    "        \"Carrier Failure\"\n",
    "    ])\n",
    "\n",
    "]\n",
    "\n",
    "\n",
    "assert (\n",
    "\n",
    "    (\n",
    "        logistics_incidents[\"delay_ratio\"]\n",
    "\n",
    "        > 0.05\n",
    "    ).mean()\n",
    "\n",
    "    > 0.60\n",
    "\n",
    "), (\n",
    "\n",
    "    \"Logistics incidents poorly correlated with shipment delays\"\n",
    ")\n",
    "\n",
    "\n",
    "print(\"✓ Shipment correlation validation passed\")"
   ]
