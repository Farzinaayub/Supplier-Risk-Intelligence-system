    "\n",
    "), \"Duplicate audit_id detected\"\n",
    "\n",
    "\n",
    "# ---------------------------------------------------------\n",
    "# Mandatory columns not null\n",
    "# ---------------------------------------------------------\n",
    "\n",
    "mandatory_cols = [\n",
    "\n",
    "    \"audit_id\",\n",
    "    \"supplier_id\",\n",
    "    \"audit_date\",\n",
    "    \"audit_score\",\n",
    "    \"major_findings\",\n",
    "    \"minor_findings\",\n",
    "    \"compliance_status\"\n",
    "\n",
    "]\n",
    "\n",
    "\n",
    "assert (\n",
    "\n",
    "    df_supplier_audits[mandatory_cols]\n",
    "\n",
    "    .isnull()\n",
    "\n",
    "    .sum()\n",
    "\n",
    "    .sum()\n",
    "\n",
    "    == 0\n",
    "\n",
    "), \"Null values detected in mandatory audit columns\"\n",
    "\n",
    "\n",
    "print(\"✓ Structural validation passed\")\n",
    "\n",
    "\n",
    "# =========================================================\n",
    "# 2. SUPPLIER FK VALIDATION\n",
    "# =========================================================\n",
    "\n",
    "print(\"\\n2. SUPPLIER FK VALIDATION\")\n",
    "\n",
    "\n",
    "assert (\n",
    "\n",
    "    df_supplier_audits[\"supplier_id\"]\n",
    "\n",
    "    .isin(df_suppliers[\"supplier_id\"])\n",
    "\n",
    "    .all()\n",
    "\n",
    "), \"Invalid supplier_id found in audit table\"\n",
    "\n",
    "\n",
    "print(\"✓ Supplier FK validation passed\")\n",
    "\n",
    "\n",
    "# =========================================================\n",
    "# 3. AUDIT SCORE SANITY\n",
    "# =========================================================\n",
    "\n",
    "print(\"\\n3. AUDIT SCORE SANITY\")\n",
    "\n",
    "\n",
    "# ---------------------------------------------------------\n",
    "# Score range validation\n",
    "# ---------------------------------------------------------\n",
    "\n",
    "assert (\n",
    "\n",
    "    (\n",
    "        df_supplier_audits[\"audit_score\"] >= 0\n",
    "    )\n",
    "\n",
    "    &\n",
    "\n",
    "    (\n",
    "        df_supplier_audits[\"audit_score\"] <= 100\n",
    "    )\n",
    "\n",
    ").all(), \"Invalid audit_score outside range 0-100\"\n",
    "\n",
    "\n",
    "# ---------------------------------------------------------\n",
    "# Findings cannot be negative\n",
    "# ---------------------------------------------------------\n",
    "\n",
    "assert (\n",
    "\n",
    "    df_supplier_audits[\"major_findings\"] >= 0\n",
    "\n",
    ").all(), \"Negative major findings detected\"\n",
    "\n",
    "\n",
    "assert (\n",
    "\n",
    "    df_supplier_audits[\"minor_findings\"] >= 0\n",
    "\n",
    ").all(), \"Negative minor findings detected\"\n",
    "\n",
    "\n",
    "print(\"✓ Audit score sanity passed\")\n",
    "\n",
    "\n",
    "# =========================================================\n",
    "# 4. COMPLIANCE STATUS CONSISTENCY\n",
    "# =========================================================\n",
    "\n",
    "print(\"\\n4. COMPLIANCE STATUS CONSISTENCY\")\n",
    "\n",
    "\n",
    "# ---------------------------------------------------------\n",
    "# Validate compliance logic\n",
    "# ---------------------------------------------------------\n",
    "\n",
    "def expected_status(score):\n",
    "\n",
    "    if score >= 90:\n",
    "        return \"Compliant\"\n",
    "\n",
    "    elif score >= 75:\n",
    "        return \"Conditional\"\n",
    "\n",
    "    elif score >= 60:\n",
    "        return \"Under Review\"\n",
    "\n",
    "    else:\n",
    "        return \"Non-Compliant\"\n",
    "\n",
    "\n",
    "df_supplier_audits[\"expected_status\"] = (\n",
    "\n",
    "    df_supplier_audits[\"audit_score\"]\n",
    "\n",
    "    .apply(expected_status)\n",
    "\n",
    ")\n",
    "\n",
    "\n",
    "invalid_status = df_supplier_audits[\n",
    "\n",
    "    df_supplier_audits[\"compliance_status\"]\n",
    "\n",
    "    !=\n",
    "\n",
    "    df_supplier_audits[\"expected_status\"]\n",
    "\n",
    "]\n",
    "\n",
    "\n",
    "assert (\n",
    "\n",
    "    len(invalid_status) == 0\n",
    "\n",
    "), \"Compliance status inconsistent with audit_score\"\n",
    "\n",
    "\n",
    "print(\"✓ Compliance status validation passed\")\n",
    "\n",
    "\n",
    "# =========================================================\n",
    "# 5. SHIPMENT PERFORMANCE CORRELATION\n",
    "# =========================================================\n",
    "\n",
    "print(\"\\n5. SHIPMENT PERFORMANCE VALIDATION\")\n",
    "\n",
    "\n",
    "# ---------------------------------------------------------\n",
    "# Build shipment delay metrics\n",
    "# ---------------------------------------------------------\n",
    "\n",
    "shipment_metrics = (\n",
    "\n",
    "    df_shipments\n",
    "\n",
    "    .groupby(\"supplier_id\")\n",
    "\n",
    "    .agg(\n",
    "\n",
    "        total_shipments=(\n",
    "            \"shipment_id\",\n",
    "            \"count\"\n",
    "        ),\n",
    "\n",
    "        delayed_shipments=(\n",
    "            \"shipment_status\",\n",
    "            lambda x:\n",
    "                (x == \"Delayed\").sum()\n",
    "        )\n",
    "\n",
    "    )\n",
    "\n",
    "    .reset_index()\n",
    "\n",
    ")\n",
    "\n",
    "\n",
    "shipment_metrics[\"delay_ratio\"] = (\n",
    "\n",
    "    shipment_metrics[\"delayed_shipments\"]\n",
    "\n",
    "    /\n",
    "\n",
    "    shipment_metrics[\"total_shipments\"]\n",
    "\n",
    ")\n",
    "\n",
    "\n",
    "# ---------------------------------------------------------\n",
    "# Merge audit scores\n",
    "# ---------------------------------------------------------\n",
    "\n",
    "shipment_audit = df_supplier_audits.merge(\n",
    "\n",
    "    shipment_metrics[[\n",
    "        \"supplier_id\",\n",
    "        \"delay_ratio\"\n",
    "    ]],\n",
    "\n",
    "    on=\"supplier_id\",\n",
    "\n",
    "    how=\"left\"\n",
    "\n",
    ")\n",
    "\n",
    "\n",
    "shipment_audit[\"delay_ratio\"] = (\n",
    "\n",
    "    shipment_audit[\"delay_ratio\"]\n",
    "\n",
    "    .fillna(0)\n",
    "\n",
    ")\n",
    "\n",
    "\n",
    "# ---------------------------------------------------------\n",
    "# Suppliers with extreme delay ratios\n",
    "# should not have elite scores\n",
    "# ---------------------------------------------------------\n",
    "\n",
    "bad_delay_suppliers = shipment_audit[\n",
    "\n",
    "    shipment_audit[\"delay_ratio\"] > 0.50\n",
    "\n",
    "]\n",
    "\n",
    "\n",
    "assert (\n",
    "\n",
    "    (\n",
    "        bad_delay_suppliers[\"audit_score\"]\n",
    "        < 95\n",
    "    ).all()\n",
    "\n",
    "), (\n",
    "\n",
    "    \"Highly delayed suppliers have unrealistic audit scores\"\n",
    ")\n",
    "\n",
    "\n",
    "print(\"✓ Shipment correlation validation passed\")\n",
    "\n",
    "\n",
    "# =========================================================\n",
    "# 6. QUALITY CORRELATION VALIDATION\n",
    "# =========================================================\n",
    "\n",
    "print(\"\\n6. QUALITY CORRELATION VALIDATION\")\n",
    "\n",
    "\n",
    "# ---------------------------------------------------------\n",
    "# Build supplier defect rates\n",
    "# ---------------------------------------------------------\n",
    "\n",
    "quality_metrics = (\n",
    "\n",
    "    df_quality_inspections\n",
    "\n",
    "    .groupby(\"supplier_id\")\n",
    "\n",
    "    .agg(\n",
    "\n",
    "        total_inspected=(\n",
    "            \"inspected_units\",\n",
    "            \"sum\"\n",
    "        ),\n",
    "\n",
    "        total_rejected=(\n",
    "            \"rejected_units\",\n",
    "            \"sum\"\n",
    "        )\n",
    "\n",
    "    )\n",
    "\n",
    "    .reset_index()\n",
    "\n",
    ")\n",
    "\n",
    "\n",
    "quality_metrics[\"rejection_ratio\"] = (\n",
    "\n",
    "    quality_metrics[\"total_rejected\"]\n",
    "\n",
    "    /\n",
    "\n",
    "    quality_metrics[\"total_inspected\"]\n",
    "\n",
    ")\n",
    "\n",
    "quality_metrics[\"rejection_ratio\"] = (\n",
    "\n",
    "    quality_metrics[\"rejection_ratio\"]\n",
    "\n",
    "    .fillna(0)\n",
    "\n",
    ")\n",
    "\n",
    "\n",
    "quality_audit = df_supplier_audits.merge(\n",
    "\n",
    "    quality_metrics[[\n",
    "        \"supplier_id\",\n",
    "        \"rejection_ratio\"\n",
    "    ]],\n",
    "\n",
    "    on=\"supplier_id\",\n",
    "\n",
    "    how=\"left\"\n",
    "\n",
    ")\n",
    "\n",
    "\n",
    "quality_audit[\"rejection_ratio\"] = (\n",
    "\n",
    "    quality_audit[\"rejection_ratio\"]\n",
    "\n",
    "    .fillna(0)\n",
    "\n",
    ")\n",
    "\n",
    "\n",
    "# ---------------------------------------------------------\n",
    "# High rejection suppliers should not\n",
    "# have near-perfect audits\n",
    "# ---------------------------------------------------------\n",
    "\n",
    "bad_quality_suppliers = quality_audit[\n",
    "\n",
    "    quality_audit[\"rejection_ratio\"] > 0.10\n",
    "\n",
    "]\n",
    "\n",
    "\n",
    "assert (\n",
    "\n",
    "    (\n",
    "        bad_quality_suppliers[\"audit_score\"]\n",
    "        < 95\n",
    "    ).all()\n",
    "\n",
    "), (\n",
    "\n",
    "    \"Poor quality suppliers have unrealistic audit scores\"\n",
    ")\n",
    "\n",
    "\n",
    "print(\"✓ Quality correlation validation passed\")\n",
    "\n",
    "\n",
    "# =========================================================\n",
    "# 7. INVENTORY RISK CORRELATION\n",
    "# =========================================================\n",
    "\n",
    "print(\"\\n7. INVENTORY RISK VALIDATION\")\n",
    "\n",
    "\n",
    "# ---------------------------------------------------------\n",
    "# Build low-stock risk\n",
    "# ---------------------------------------------------------\n",
    "\n",
    "inventory_risk = (\n",
    "\n",
    "    df_inventory\n",
    "\n",
    "    .groupby(\"supplier_id\")\n",
    "\n",
    "    .apply(\n",
    "\n",
    "        lambda x:\n",
    "\n",
    "        (\n",
    "            x[\"current_stock\"]\n",
    "\n",
    "            <\n",
    "\n",
    "            x[\"safety_stock\"]\n",
    "\n",
    "        ).mean()\n",
    "\n",
    "    )\n",
    "\n",
    "    .reset_index(name=\"low_stock_ratio\")\n",
    "\n",
    ")\n",
    "\n",
    "\n",
    "inventory_audit = df_supplier_audits.merge(\n",
    "\n",
    "    inventory_risk,\n",
    "\n",
    "    on=\"supplier_id\",\n",
    "\n",
    "    how=\"left\"\n",
    "\n",
    ")\n",
    "\n",
    "\n",
    "inventory_audit[\"low_stock_ratio\"] = (\n",
    "\n",
    "    inventory_audit[\"low_stock_ratio\"]\n",
    "\n",
    "    .fillna(0)\n",
    "\n",
    ")\n",
    "\n",
    "\n",
    "# ---------------------------------------------------------\n",
    "# Severe stock instability should reduce scores\n",
    "# ---------------------------------------------------------\n",
    "\n",
    "high_risk_inventory = inventory_audit[\n",
    "\n",
    "    inventory_audit[\"low_stock_ratio\"] > 0.70\n",
    "\n",
    "]\n",
    "\n",
    "\n",
    "assert (\n",
    "\n",
    "    (\n",
    "        high_risk_inventory[\"audit_score\"]\n",
    "        < 95\n",
    "    ).all()\n",
    "\n",
    "), (\n",
    "\n",
    "    \"Inventory unstable suppliers have unrealistic audit scores\"\n",
    ")\n",
    "\n",
    "\n",
    "print(\"✓ Inventory correlation validation passed\")\n",
    "\n",
    "\n",
    "# =========================================================\n",
    "# 8. CRITICALITY VALIDATION\n",
    "# =========================================================\n",
    "\n",
    "print(\"\\n8. CRITICALITY VALIDATION\")\n",
    "\n",
    "\n",
    "supplier_criticality = df_suppliers[[\n",
    "\n",
    "    \"supplier_id\",\n",
    "    \"criticality_level\"\n",
    "\n",
    "]]\n",
    "\n",
    "\n",
    "audit_criticality = df_supplier_audits.merge(\n",
    "\n",
    "    supplier_criticality,\n",
    "\n",
    "    on=\"supplier_id\",\n",
    "\n",
    "    how=\"left\"\n",
    "\n",
    ")\n",
    "\n",
    "\n",
    "# ---------------------------------------------------------\n",
    "# High critical suppliers should\n",
    "# generally have more audits\n",
    "# ---------------------------------------------------------\n",
    "\n",
    "audit_frequency = (\n",
    "\n",
    "    audit_criticality\n",
    "\n",
    "    .groupby([\n",
    "        \"supplier_id\",\n",
    "        \"criticality_level\"\n",
    "    ])\n",
    "\n",
    "    .size()\n",
    "\n",
    "    .reset_index(name=\"audit_count\")\n",
    "\n",
    ")\n",
    "\n",
    "\n",
    "critical_suppliers = audit_frequency[\n",
    "\n",
    "    audit_frequency[\"criticality_level\"] >= 4\n",
    "\n",
    "]\n",
    "\n",
    "\n",
    "assert (\n",
    "\n",
    "    (\n",
    "        critical_suppliers[\"audit_count\"] >= 2\n",
    "    ).all()\n",
    "\n",
    "), (\n",
    "\n",
    "    \"Critical suppliers insufficiently audited\"\n",
    ")\n",
    "\n",
    "\n",
    "print(\"✓ Criticality validation passed\")\n",
    "\n",
    "\n",
    "# =========================================================\n",
    "# 9. TEMPORAL VALIDATION\n",
    "# =========================================================\n",
    "\n",
    "print(\"\\n9. TEMPORAL VALIDATION\")\n",
    "\n",
    "\n",
    "# ---------------------------------------------------------\n",
    "# Audit dates should be realistic\n",
    "# ---------------------------------------------------------\n",
    "\n",
    "assert (\n",
    "\n",
    "    pd.to_datetime(\n",
    "        df_supplier_audits[\"audit_date\"]\n",
    "    )\n",
    "\n",
    "    >=\n",
    "\n",
    "    pd.Timestamp(\"2024-01-01\")\n",
    "\n",
    ").all(), \"Invalid historical audit dates\"\n",
    "\n",
    "\n",
    "assert (\n",
    "\n",
    "    pd.to_datetime(\n",
    "        df_supplier_audits[\"audit_date\"]\n",
    "    )\n",
    "\n",
    "    <=\n",
    "\n",
    "    pd.Timestamp(\"2026-12-31\")\n",
    "\n",
    ").all(), \"Future audit dates unrealistic\"\n",
    "\n",
    "\n",
    "print(\"✓ Temporal validation passed\")\n",
    "\n",
    "\n",
    "# =========================================================\n",
    "# 10. STATISTICAL REALISM\n",
    "# =========================================================\n",
    "\n",
    "print(\"\\n10. STATISTICAL REALISM\")\n",
    "\n",
    "\n",
    "# ---------------------------------------------------------\n",
    "# Audit score variance\n",
    "# ---------------------------------------------------------\n",
    "\n",
    "assert (\n",
    "\n",
    "    df_supplier_audits[\"audit_score\"]\n",
    "\n",
    "    .std()\n",
    "\n",
    "    > 5\n",
    "\n",
    "), \"Audit scores lack realistic variance\"\n",
    "\n",
    "\n",
    "# ---------------------------------------------------------\n",
    "# Compliance distribution sanity\n",
    "# ---------------------------------------------------------\n",
    "\n",
    "compliance_distribution = (\n",
    "\n",
    "    df_supplier_audits[\"compliance_status\"]\n",
    "\n",
    "    .value_counts(normalize=True)\n",
    "\n",
    ")\n",
    "\n",
    "\n",
    "assert (\n",
    "\n",
    "    compliance_distribution.max()\n",
    "\n",
    "    < 0.95\n",
    "\n",
    "), \"Compliance distribution unrealistically skewed\"\n",
    "\n",
    "\n",
    "print(\"✓ Statistical realism validation passed\")\n",
    "\n",
    "\n",
    "# =========================================================\n",
    "# 11. MAJOR FINDINGS CORRELATION\n",
    "# =========================================================\n",
    "\n",
    "print(\"\\n11. FINDINGS CORRELATION VALIDATION\")\n",
    "\n",
    "\n",
    "# ---------------------------------------------------------\n",
    "# Low audit scores should correlate\n",
    "# with more major findings\n",
    "# ---------------------------------------------------------\n",
    "\n",
    "bad_audits = df_supplier_audits[\n",
    "\n",
    "    df_supplier_audits[\"audit_score\"] < 70\n",
    "\n",
    "]\n",
    "\n",
    "\n",
    "assert (\n",
    "\n",
    "    (\n",
    "        bad_audits[\"major_findings\"] >= 1\n",
    "    ).mean()\n",
    "\n",
    "    > 0.60\n",
    "\n",
    "), (\n",
    "\n",
    "    \"Low audit scores not correlated with findings\"\n",
    ")\n",
    "\n",
    "\n",
    "print(\"✓ Findings correlation validation passed\")\n",
    "\n",
    "\n",
    "# =========================================================\n",
    "# FINAL SUMMARY\n",
    "# =========================================================\n",
    "\n",
    "print(\"\\n===================================\")\n",
    "print(\"ALL AUDIT VALIDATIONS PASSED\")\n",
    "print(\"===================================\\n\")\n",
    "\n",
    "\n",
    "print(\"Validation Summary:\")\n",
    "\n",
    "print(\n",
    "    f\"Total Audits: \"\n",
    "    f\"{len(df_supplier_audits)}\"\n",
    ")\n",
    "\n",
    "print(\n",
    "    f\"Audited Suppliers: \"\n",
    "    f\"{df_supplier_audits['supplier_id'].nunique()}\"\n",
    ")\n",
    "\n",
    "print(\n",
    "    f\"Average Audit Score: \"\n",
    "    f\"{round(df_supplier_audits['audit_score'].mean(), 2)}\"\n",
    ")\n",
    "\n",
    "print(\n",
    "    f\"Compliance Distribution:\\n\"\n",
    ")\n",
    "\n",
    "print(\n",
    "    df_supplier_audits[\n",
    "        \"compliance_status\"\n",
    "    ].value_counts()\n",
    ")\n",
    "\n",
    "print(\"\\nEnterprise audit validation complete.\")"
   ]
  },
