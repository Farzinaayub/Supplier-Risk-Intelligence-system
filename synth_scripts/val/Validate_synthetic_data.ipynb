    "# =========================================================\n",
    "# 8. INVENTORY CORRELATION VALIDATION\n",
    "# =========================================================\n",
    "\n",
    "print(\"\\n8. INVENTORY CORRELATION VALIDATION\")\n",
    "\n",
    "\n",
    "inventory_metrics = (\n",
    "\n",
    "    df_inventory\n",
    "\n",
    "    .groupby(\"supplier_id\")\n",
    "\n",
    "    .apply(\n",
    "\n",
    "        lambda x:\n",
    "\n",
    "        (\n",
    "            x[\"current_stock\"]\n",
    "\n",
    "            <\n",
    "\n",
    "            x[\"safety_stock\"]\n",
    "\n",
    "        ).mean()\n",
    "\n",
    "    )\n",
    "\n",
    "    .reset_index(name=\"low_stock_ratio\")\n",
    "\n",
    ")\n",
    "\n",
    "\n",
    "incident_inventory = df_supplier_incidents.merge(\n",
    "\n",
    "    inventory_metrics,\n",
    "\n",
    "    on=\"supplier_id\",\n",
    "\n",
    "    how=\"left\"\n",
    "\n",
    ")\n",
    "\n",
    "\n",
    "incident_inventory[\"low_stock_ratio\"] = (\n",
    "\n",
    "    incident_inventory[\"low_stock_ratio\"]\n",
    "\n",
    "    .fillna(0)\n",
    "\n",
    ")\n",
    "\n",
    "\n",
    "stock_incidents = incident_inventory[\n",
    "\n",
    "    incident_inventory[\"incident_type\"]\n",
    "\n",
    "    .isin([\n",
    "        \"Stockout\",\n",
    "        \"Supply Shortage\"\n",
    "    ])\n",
    "\n",
    "]\n",
    "\n",
    "\n",
    "assert (\n",
    "\n",
    "    (\n",
    "        stock_incidents[\"low_stock_ratio\"]\n",
    "\n",
    "        > 0.20\n",
    "    ).mean()\n",
    "\n",
    "    > 0.60\n",
    "\n",
    "), (\n",
    "\n",
    "    \"Inventory incidents poorly correlated with low stock\"\n",
    ")\n",
    "\n",
    "\n",
    "print(\"✓ Inventory correlation validation passed\")\n",
    "\n",
    "\n",
    "# =========================================================\n",
    "# 9. AUDIT CORRELATION VALIDATION\n",
    "# =========================================================\n",
    "\n",
    "print(\"\\n9. AUDIT CORRELATION VALIDATION\")\n",
    "\n",
    "\n",
    "audit_metrics = (\n",
    "\n",
    "    df_supplier_audits\n",
    "\n",
    "    .groupby(\"supplier_id\")\n",
    "\n",
    "    .agg(\n",
    "\n",
    "        avg_audit_score=(\n",
    "            \"audit_score\",\n",
    "            \"mean\"\n",
    "        )\n",
    "\n",
    "    )\n",
    "\n",
    "    .reset_index()\n",
    "\n",
    ")\n",
    "\n",
    "\n",
    "incident_audit = df_supplier_incidents.merge(\n",
    "\n",
    "    audit_metrics,\n",
    "\n",
    "    on=\"supplier_id\",\n",
    "\n",
    "    how=\"left\"\n",
    "\n",
    ")\n",
    "\n",
    "\n",
    "incident_audit[\"avg_audit_score\"] = (\n",
    "\n",
    "    incident_audit[\"avg_audit_score\"]\n",
    "\n",
    "    .fillna(100)\n",
    "\n",
    ")\n",
    "\n",
    "\n",
    "compliance_incidents = incident_audit[\n",
    "\n",
    "    incident_audit[\"incident_type\"]\n",
    "\n",
    "    .isin([\n",
    "        \"Audit Non-Compliance\",\n",
    "        \"Regulatory Violation\"\n",
    "    ])\n",
    "\n",
    "]\n",
    "\n",
    "\n",
    "assert (\n",
    "\n",
    "    (\n",
    "        compliance_incidents[\"avg_audit_score\"]\n",
    "\n",
    "        < 85\n",
    "    ).mean()\n",
    "\n",
    "    > 0.60\n",
    "\n",
    "), (\n",
    "\n",
    "    \"Compliance incidents poorly correlated with audits\"\n",
    ")\n",
    "\n",
    "\n",
    "print(\"✓ Audit correlation validation passed\")\n",
    "\n",
    "\n",
    "# =========================================================\n",
    "# 10. CRITICALITY VALIDATION\n",
    "# =========================================================\n",
    "\n",
    "print(\"\\n10. CRITICALITY VALIDATION\")\n",
    "\n",
    "\n",
    "supplier_criticality = df_suppliers[[\n",
    "\n",
    "    \"supplier_id\",\n",
    "    \"criticality_level\"\n",
    "\n",
    "]]\n",
    "\n",
    "\n",
    "incident_criticality = df_supplier_incidents.merge(\n",
    "\n",
    "    supplier_criticality,\n",
    "\n",
    "    on=\"supplier_id\",\n",
    "\n",
    "    how=\"left\"\n",
    "\n",
    ")\n",
    "\n",
    "\n",
    "critical_incidents = incident_criticality[\n",
    "\n",
    "    incident_criticality[\"severity\"]\n",
    "\n",
    "    == \"Critical\"\n",
    "\n",
    "]\n",
    "\n",
    "\n",
    "assert (\n",
    "\n",
    "    (\n",
    "        critical_incidents[\"criticality_level\"]\n",
    "\n",
    "        >= 3\n",
    "    ).mean()\n",
    "\n",
    "    > 0.50\n",
    "\n",
    "), (\n",
    "\n",
    "    \"Critical incidents poorly aligned with supplier criticality\"\n",
    ")\n",
    "\n",
    "\n",
    "print(\"✓ Criticality validation passed\")\n",
    "\n",
    "\n",
    "# =========================================================\n",
    "# 11. TEMPORAL VALIDATION\n",
    "# =========================================================\n",
    "\n",
    "print(\"\\n11. TEMPORAL VALIDATION\")\n",
    "\n",
    "\n",
    "incident_dates = pd.to_datetime(\n",
    "\n",
    "    df_supplier_incidents[\"incident_date\"]\n",
    "\n",
    ")\n",
    "\n",
    "\n",
    "assert (\n",
    "\n",
    "    incident_dates\n",
    "\n",
    "    >=\n",
    "\n",
    "    pd.Timestamp(\"2024-01-01\")\n",
    "\n",
    ").all(), \"Invalid historical incident dates\"\n",
    "\n",
    "\n",
    "assert (\n",
    "\n",
    "    incident_dates\n",
    "\n",
    "    <=\n",
    "\n",
    "    pd.Timestamp(\"2026-12-31\")\n",
    "\n",
    ").all(), \"Unrealistic future incident dates\"\n",
    "\n",
    "\n",
    "print(\"✓ Temporal validation passed\")\n",
    "\n",
    "\n",
    "# =========================================================\n",
    "# 12. STATISTICAL REALISM\n",
    "# =========================================================\n",
    "\n",
    "print(\"\\n12. STATISTICAL REALISM\")\n",
    "\n",
    "\n",
    "# ---------------------------------------------------------\n",
    "# Severity distribution sanity\n",
    "# ---------------------------------------------------------\n",
    "\n",
    "severity_distribution = (\n",
    "\n",
    "    df_supplier_incidents[\"severity\"]\n",
    "\n",
    "    .value_counts(normalize=True)\n",
    "\n",
    ")\n",
    "\n",
    "\n",
    "assert (\n",
    "\n",
    "    severity_distribution.max()\n",
    "\n",
    "    < 0.95\n",
    "\n",
    "), \"Incident severity distribution unrealistic\"\n",
    "\n",
    "\n",
    "# ---------------------------------------------------------\n",
    "# Impact hour variance\n",
    "# ---------------------------------------------------------\n",
    "\n",
    "assert (\n",
    "\n",
    "    df_supplier_incidents[\n",
    "        \"operational_impact_hours\"\n",
    "    ].std()\n",
    "\n",
    "    > 5\n",
    "\n",
    "), \"Impact hours lack realistic variance\"\n",
    "\n",
    "\n",
    "print(\"✓ Statistical realism validation passed\")\n",
    "\n",
    "\n",
    "# =========================================================\n",
    "# FINAL SUMMARY\n",
    "# =========================================================\n",
    "\n",
    "print(\"\\n===================================\")\n",
    "print(\"ALL INCIDENT VALIDATIONS PASSED\")\n",
    "print(\"===================================\\n\")\n",
    "\n",
    "\n",
    "print(\"Validation Summary:\")\n",
    "\n",
    "print(\n",
    "    f\"Total Incidents: \"\n",
    "    f\"{len(df_supplier_incidents)}\"\n",
    ")\n",
    "\n",
    "print(\n",
    "    f\"Impacted Suppliers: \"\n",
    "    f\"{df_supplier_incidents['supplier_id'].nunique()}\"\n",
    ")\n",
    "\n",
    "print(\n",
    "    f\"Average Impact Hours: \"\n",
    "    f\"{round(df_supplier_incidents['operational_impact_hours'].mean(), 2)}\"\n",
    ")\n",
    "\n",
    "print(\"\\nSeverity Distribution:\\n\")\n",
    "\n",
    "print(\n",
    "    df_supplier_incidents[\n",
    "        \"severity\"\n",
    "    ].value_counts()\n",
    ")\n",
    "\n",
    "print(\"\\nEnterprise incident validation complete.\")"
   ]
