# ============================================
# Supplier Risk Intelligence – Environment Variables
# ============================================
# Copy this file to .env and fill in real values.
# Never commit .env to version control.

# --------------------------------------------
# Database (PostgreSQL)
# --------------------------------------------
DB_HOST=postgres
DB_PORT=5432
DB_NAME=supplier_risk
DB_USER=supplier_user
DB_PASSWORD=change_me_strong_password_here

# --------------------------------------------
# n8n (Workflow Automation)
# --------------------------------------------
N8N_PORT=5678
N8N_PROTOCOL=http
N8N_HOST=localhost
# Basic auth for n8n UI (optional but recommended)
N8N_BASIC_AUTH_ACTIVE=true
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=change_me_n8n_password
# n8n encryption key (generate with `openssl rand -hex 24`)
N8N_ENCRYPTION_KEY=replace_with_32_character_hex_string
# API key for programmatic workflow triggers (optional)
N8N_API_KEY=n8n_api_placeholder_replace_me

# --------------------------------------------
# Slack Alerts (webhook)
# --------------------------------------------
# Create a Slack app with incoming webhook, then paste the URL
SLACK_WEBHOOK_URL=""

# --------------------------------------------
# Email (SMTP) – for weekly reports and alerts
# --------------------------------------------
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password_or_smtp_password
SMTP_FROM=risk-alerts@supplier-intelligence.com
SMTP_TO=procurement@client-company.de

# --------------------------------------------
# Pseudonymisation Adapter (Docker sidecar)
# --------------------------------------------
# Enable only if client sends raw PII (default: false)
PSEUDONYM_ADAPTER_ENABLED=false
# Salt for deterministic hashing (SHA-256). Generate once per client.
PSEUDONYM_SALT=random_salt_32_bytes_minimum
# Remove columns matching these patterns (regex, comma-separated)
PII_REDACT_PATTERNS=email,phone,name

# --------------------------------------------
# License & Maintenance (Client Lock‑in)
# --------------------------------------------
# License key – embedded in the system; expires every 30 days.
# Generate via `python scripts/generate_license.py --expiry 2025-06-01`
LICENSE_KEY=XXXXX-XXXXX-XXXXX-XXXXX
# Encryption key for model parameters (GMM weights, control limits)
# Only the maintainer (you) knows this; client cannot change parameters.
PARAMETER_ENCRYPTION_KEY=fernet_key_32_bytes_base64

# --------------------------------------------
# Data Freshness Monitoring
# --------------------------------------------
# Max allowed hours since last delivery record before alert
MAX_DATA_STALE_HOURS=48

# --------------------------------------------
# Model & Control Parameters (tuned by maintainer)
# --------------------------------------------
# EWMA smoothing factor (lambda) – default 0.2
EWMA_LAMBDA=0.2
# Control limit multiplier (L) for Shewhart/EWMA – default 3.0
CONTROL_LIMIT_L=3.0
# Service level for safety stock calculation (0.95 = 95%, 0.99 = 99%)
SERVICE_LEVEL_TARGET=0.99
# Number of clusters (GMM) – default determined by gap statistic, but can be overridden
N_CLUSTERS=5

# --------------------------------------------
# Optional: External APIs (Geopolitical risk)
# --------------------------------------------
# GDELT API (free, no key needed usually, but can add rate limiting)
GDELT_BASE_URL=https://api.gdeltproject.org/api/v2/events/events
# Destatis (German statistics) – if used for benchmarking
DESTATIS_API_KEY=optional_placeholder

# --------------------------------------------
# Logging & Debug (development only)
# --------------------------------------------
LOG_LEVEL=INFO  # DEBUG, INFO, WARNING, ERROR
DEBUG_MODE=false

# --------------------------------------------
# Backup (optional – Hetzner Storage Box example)
# --------------------------------------------
BACKUP_ENABLED=false
BACKUP_SERVER=your_storage_box_hostname
BACKUP_USER=user
BACKUP_PASSWORD=password
BACKUP_PATH=/backups/supplier-risk