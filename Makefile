# ============================================================================
# Supplier Risk Platform - Developer Shortcuts
# ============================================================================

# Default compose command
COMPOSE=docker compose

# ---------------------------------------------------------------------------
# Start all services
# Usage:
#   make up
# ---------------------------------------------------------------------------
up:
	$(COMPOSE) up -d

# ---------------------------------------------------------------------------
# Stop all services
# Usage:
#   make down
# ---------------------------------------------------------------------------
down:
	$(COMPOSE) down

# ---------------------------------------------------------------------------
# Rebuild containers
# Usage:
#   make build
# ---------------------------------------------------------------------------
build:
	$(COMPOSE) build

# ---------------------------------------------------------------------------
# View logs
# Usage:
#   make logs
# ---------------------------------------------------------------------------
logs:
	$(COMPOSE) logs -f

# ---------------------------------------------------------------------------
# Show running containers
# Usage:
#   make ps
# ---------------------------------------------------------------------------
ps:
	$(COMPOSE) ps

# ---------------------------------------------------------------------------
# Seed/generate synthetic supplier data
# Usage:
#   make seed
# ---------------------------------------------------------------------------
seed:
	$(COMPOSE) run --rm app python scripts/generate_suppliers.py

# ---------------------------------------------------------------------------
# Open shell inside app container
# Usage:
#   make shell
# ---------------------------------------------------------------------------
shell:
	$(COMPOSE) exec app bash

# ---------------------------------------------------------------------------
# Run dbt models
# Usage:
#   make dbt-run
# ---------------------------------------------------------------------------
dbt-run:
	$(COMPOSE) run --rm app dbt run --project-dir /app/dbt

# ---------------------------------------------------------------------------
# Run dbt tests
# Usage:
#   make dbt-test
# ---------------------------------------------------------------------------
dbt-test:
	$(COMPOSE) run --rm app dbt test --project-dir /app/dbt

# ---------------------------------------------------------------------------
# Clean everything INCLUDING volumes
# WARNING: deletes database data
# Usage:
#   make clean
# ---------------------------------------------------------------------------
clean:
	$(COMPOSE) down -v